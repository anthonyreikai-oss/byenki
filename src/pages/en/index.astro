---
import { getBlogPosts } from "../../data/blog";
import PostLayout from "../../layouts/PostLayout.astro";

const locale = "en";
const allPosts = await getBlogPosts(locale);

if (!allPosts.length) {
  return Astro.redirect('/en/blog');
}

const latestPost = allPosts[0];
const { Content } = await latestPost.render();

const idx = 0;
const prevPost = idx < allPosts.length - 1 ? allPosts[idx + 1] : null;
const nextPost = null;
---

<PostLayout post={latestPost} prevPost={prevPost} nextPost={nextPost} locale={locale}>
  <Content />
</PostLayout>
