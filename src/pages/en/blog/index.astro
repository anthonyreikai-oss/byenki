---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BlogContent from '../../../components/react/BlogContent';
import { t } from '../../../i18n/ui';
import theme from '../../../../theme.config';

const locale = "en" as const;
---

<BaseLayout
  title={t('blog.title', locale)}
  description={t('site.description', locale)}
  locale={locale}
>
  <Fragment slot="head">
    <meta name="keywords" content={t('blog.keywords', locale)} />
  </Fragment>
  <Header locale={locale} />
  <main class="min-h-screen bg-w-black text-w-cream relative">
    <div class="absolute inset-0 pointer-events-none z-0 overflow-hidden opacity-5">
      <div class="max-w-screen-2xl mx-auto h-full w-full border-x border-dashed border-dashed-cream flex justify-between">
        <div class="w-1/4 h-full border-r border-dashed border-dashed-cream"></div>
        <div class="w-1/4 h-full border-r border-dashed border-dashed-cream"></div>
        <div class="w-1/4 h-full border-r border-dashed border-dashed-cream"></div>
      </div>
    </div>

    <div class="relative z-10 pb-12">
      <BlogContent client:load locale={locale} social={{ instagram: theme.social.instagram, linkedin: theme.social.linkedin }} />
    </div>
  </main>
  <Footer locale={locale} />
</BaseLayout>
