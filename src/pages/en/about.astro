---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { t } from "../../i18n/ui";

const locale = "en" as const;
const blogPath = '/en/blog';
const homePath = '/en';
---

<BaseLayout title={t('about.title', locale)} description={t('about.description', locale)} locale={locale}>
  <Header locale={locale} />
  <main class="min-h-screen bg-w-black text-w-cream relative">
    <div class="absolute inset-0 pointer-events-none z-0 overflow-hidden opacity-5">
      <div class="max-w-screen-2xl mx-auto h-full w-full border-x border-dashed border-dashed-cream flex justify-between">
        <div class="w-1/4 h-full border-r border-dashed border-dashed-cream"></div>
        <div class="w-1/4 h-full border-r border-dashed border-dashed-cream"></div>
        <div class="w-1/4 h-full border-r border-dashed border-dashed-cream"></div>
      </div>
    </div>

    <div class="relative z-10 max-w-screen-xl mx-auto px-4 md:px-6 pt-8 pb-16">
      <div class="flex items-center justify-between mb-10">
        <a href={homePath} class="inline-flex items-center gap-2 font-mono text-xs text-w-muted hover:text-w-orange transition-colors">
          <span>←</span> {t('about.back', locale)}
        </a>
      </div>

      <div class="max-w-3xl mx-auto">
        <div class="flex items-center gap-3 mb-6 font-mono text-[10px] text-w-orange uppercase tracking-widest">
          <span class="w-8 h-px bg-w-orange/40"></span>
          <span>{t('about.whoami', locale)}</span>
        </div>

        <h1 class="font-display text-2xl sm:text-3xl md:text-4xl lg:text-5xl leading-[0.92] uppercase text-w-cream mb-8">
          {t('about.heading', locale)}
        </h1>

        <div class="font-mono text-base text-[#908D88] leading-[1.8] space-y-5 mb-14">
          <p set:html={t('about.p1', locale)} />
          <p set:html={t('about.p2', locale)} />
          <p set:html={t('about.p3', locale)} />
          <p set:html={t('about.p4', locale)} />
          <p set:html={t('about.p5', locale)} />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-14">
          <div class="border border-dashed border-dashed-cream p-5">
            <h3 class="font-mono text-[10px] uppercase tracking-widest text-w-orange mb-4 pb-3 border-b border-dashed border-dashed-cream">
              {t('about.thinking', locale)}
            </h3>
            <ul class="flex flex-col gap-3 font-mono text-sm text-w-muted">
              <li class="flex items-start gap-2">
                <span class="text-w-orange mt-0.5">▸</span>
                <span>{t('about.creative_dev', locale)}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-w-orange mt-0.5">▸</span>
                <span>{t('about.personal_growth', locale)}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-w-orange mt-0.5">▸</span>
                <span>{t('about.spiritual_dev', locale)}</span>
              </li>
            </ul>
          </div>
          <div class="border border-dashed border-dashed-cream p-5">
            <h3 class="font-mono text-[10px] uppercase tracking-widest text-w-orange mb-4 pb-3 border-b border-dashed border-dashed-cream">
              {t('about.doing', locale)}
            </h3>
            <ul class="flex flex-col gap-3 font-mono text-sm text-w-muted">
              <li class="flex items-start gap-2">
                <span class="text-w-orange mt-0.5">↗</span>
                <span>{t('about.creative_dev', locale)}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-w-orange mt-0.5">↗</span>
                <span>{t('about.personal_growth', locale)}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-w-orange mt-0.5">↗</span>
                <span>{t('about.spiritual_dev', locale)}</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="border border-dashed border-dashed-cream p-6 text-center">
          <blockquote class="font-mono text-sm text-w-muted italic mb-5 leading-relaxed">
            {t('about.quote', locale)}
          </blockquote>
          <a href={blogPath} class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-w-orange hover:text-w-cream transition-colors">
            {t('about.cta', locale)}
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer locale={locale} />
</BaseLayout>
