---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogContent from '../../components/react/BlogContent';
---

<BaseLayout
  title="Blog — INDEX.LOG | By Enki"
  description="Blog de diseño web, branding y estrategia digital en Santo Domingo. Artículos sobre WordPress, SEO local, diseño con IA y brutalismo digital."
>
  <Fragment slot="head">
    <meta name="keywords" content="blog diseño web, blog branding, blog wordpress, blog seo, santo domingo, artículos diseño web rd, blog agencia digital" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "@id": "https://byenki.dev/blog#collection",
      "name": "Blog — INDEX.LOG | By Enki",
      "description": "Blog de diseño web, branding y estrategia digital en Santo Domingo. Artículos sobre WordPress, SEO local, diseño con IA y brutalismo digital.",
      "url": "https://byenki.dev/blog",
      "about": { "@type": "Thing", "name": "Blog de diseño web y estrategia digital" }
    })} />
  </Fragment>
  <Header />
  <main class="min-h-screen bg-w-black text-w-cream relative">
    <div class="absolute inset-0 pointer-events-none z-0 overflow-hidden opacity-5">
      <div class="max-w-screen-2xl mx-auto h-full w-full border-x border-dashed border-dashed-cream flex justify-between">
        <div class="w-1/4 h-full border-r border-dashed border-dashed-cream"></div>
        <div class="w-1/4 h-full border-r border-dashed border-dashed-cream"></div>
        <div class="w-1/4 h-full border-r border-dashed border-dashed-cream"></div>
      </div>
    </div>

    <div class="relative z-10 pb-12">
      <BlogContent client:load />
    </div>
  </main>
  <Footer />
</BaseLayout>
