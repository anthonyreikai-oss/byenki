---
import { getBlogPosts } from "../data/blog";
import PostLayout from "../layouts/PostLayout.astro";

const allPosts = await getBlogPosts("es");

if (!allPosts.length) {
  return new Response('No posts yet.', { status: 404 });
}

const latestPost = allPosts[0];
const { Content } = await latestPost.render();

const idx = 0;
const prevPost = idx < allPosts.length - 1 ? allPosts[idx + 1] : null;
const nextPost = null;
---

<PostLayout post={latestPost} prevPost={prevPost} nextPost={nextPost} locale="es">
  <Content />
</PostLayout>
