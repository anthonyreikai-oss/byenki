---
import { t, type Lang } from '../i18n/ui';
import theme from '../../theme.config';

export interface Props {
  locale?: Lang;
}

const { locale = 'es' as Lang } = Astro.props as Props;
const blogPath = locale === 'en' ? '/en/blog' : '/blog';
---

<footer class="worca-footer" id="siteFooter">
  <div class="worca-footer-inner">
    <div class="worca-footer-bottom">
      <div class="worca-footer-copy">
        <span>&copy; <span id="worcaYear">2026</span> {theme.name}. <a href={theme.credit.url} target="_blank" rel="noreferrer" class="worca-enki-link">{theme.credit.text}</a></span>
      </div>

      <button class="worca-btn-top" id="btnTop">
          {t('footer.volver_arriba', locale)}
        <svg class="worca-arrow-up" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="19" x2="12" y2="5"></line>
          <polyline points="5 12 12 5 19 12"></polyline>
        </svg>
      </button>
    </div>
  </div>
</footer>

<script>
  const year = document.getElementById('worcaYear');
  if (year) year.textContent = String(new Date().getFullYear());
  const btnTop = document.getElementById('btnTop');
  btnTop?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>

<style>
  .worca-footer {
    border-top: 1px dashed color-mix(in srgb, var(--color-w-cream) 15%, transparent);
    background: var(--color-w-black);
    color: var(--color-w-cream);
  }
  .worca-footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 1.5rem 1rem;
  }
  .worca-footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .worca-footer-bottom { flex-direction: row; align-items: center; justify-content: space-between; }
  }
  .worca-footer-copy {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    color: var(--color-w-muted);
    letter-spacing: 0.05em;
  }
  .worca-enki-link { color: var(--color-w-orange); text-decoration: none; }
  .worca-enki-link:hover { color: var(--color-w-cream); }

  .worca-btn-top {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-w-orange);
    background: transparent;
    border: 1px dashed color-mix(in srgb, var(--color-w-orange) 40%, transparent);
    padding: 0.5rem 0.9rem;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .worca-btn-top:hover { background: var(--color-w-orange); color: var(--color-w-black); }
</style>
